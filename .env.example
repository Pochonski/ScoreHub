# ────────────────────────────────────────────
# ScoreHub — Variables de entorno (raíz)
# Copia este archivo a `.env` y completa los valores reales.
# El `.env` está gitignored y NUNCA debe commitearse.
# ────────────────────────────────────────────

# Competencia / temporada (Mundial 2026 = 5930 / 25)
PRIMARY_COMPETITION_ID=5930
PRIMARY_SEASON=25
CURRENT_SEASON=25
# Ventana de fechas para sync (formato YYYYMMDD)
SYNC_START_DATE=20260601
SYNC_END_DATE=20260815

# 365scores (webws.365scores.com)
SCORES365_TIMEZONE=America/Costa_Rica
SCORES365_USER_COUNTRY=153
SCORES365_LANG=14
SCORES365_APP_TYPE=5
SCORES365_POLL_MS=25000
SCORES365_MIN_INTERVAL_MS=120
SCORES365_HTTP_TIMEOUT_MS=15000

# Athlete profile cache (cache-on-read + sync TTL)
# Hydration timeout in ms: bound for getAthlete() called during web requests.
ATHLETE_HYDRATE_TIMEOUT_MS=8000
# Hydration retries inside that bound.
ATHLETE_HYDRATE_RETRIES=1
# Athletes older than this are considered stale and re-fetched by syncAthletes.
ATHLETE_STALE_AFTER_MS=86400000

# Telegram Bot
TELEGRAM_BOT_TOKEN=tu_token_de_telegram_aqui
# Live notifications (goles, tarjetas, etc.); requiere arrancar el live poller
ENABLE_LIVE_NOTIFIER=false

# Gemini AI (NLU / intent parsing)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# Database Supabase PostgreSQL
# Opción A: una sola URL (preferida — usa Supavisor pooler)
SUPABASE_DB_URL=postgresql://postgres.xxxx@aws-0-xx.pipeliner.supabase.com:6543/postgres
# Opción B: variables individuales (fallback si no hay SUPABASE_DB_URL)
DB_HOST=db.tu-proyecto.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu-password
DB_NAME=postgres
DB_SSL=true
# Pool sizing (default 25)
DB_POOL_MAX=25

# Servidores / puertos
PORT=8080
ADMIN_PORT=3001
DASHBOARD_PORT=3002
# Standalone admin (desarrollo local); en prod las rutas /admin/* viven en el bot
ADMIN_STANDALONE=false

# Logging
LOG_LEVEL=info

# Panel admin — auth por token. Si no se setea (o mide < 8 chars),
# el panel queda DESHABILITADO (503) por seguridad.
# El cliente debe enviarlo como `Authorization: Bearer <ADMIN_TOKEN>`
# o cookie `admin_token=<ADMIN_TOKEN>`.
ADMIN_TOKEN=cambia-este-token-por-uno-largo-y-aleatorio

# CORS del dashboard server (separar orígenes por coma)
CORS_ORIGINS=http://localhost:5173,https://scorehub-pocho.vercel.app

# WhatsApp (legacy, inactivo por defecto)
WA_SESSION_DIR=.wwebjs_auth
